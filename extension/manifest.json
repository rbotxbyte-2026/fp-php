{
  "manifest_version": 3,
  "name": "FP Spoofer",
  "version": "1.7.6",
  "description": "Import and spoof browser fingerprint values with anti-detection and IP-based timezone",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "webNavigation",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "world": "MAIN"
    }
  ]
}
